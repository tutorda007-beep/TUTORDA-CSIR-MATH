<question type="multichoice">
  <name><text>CSIR PYQ Unit IV Q14 — Primitive element theorem</text></name>
  <questiontext format="html">
    <text><![CDATA[The Primitive Element Theorem states that every finite separable extension \(K/F\) is:]]></text>
