  <answer fraction="100" format="html"><text><![CDATA[\(\min(\mathrm{rank}(A),\mathrm{rank}(B))\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(n\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(\max(\mathrm{rank}(A),\mathrm{rank}(B))\)]]></text><feedback format="html"><text></text></feedback></answer>
</question>
<!-- Q10 --><question type="multichoice">
