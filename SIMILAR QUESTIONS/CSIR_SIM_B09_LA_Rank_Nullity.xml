<!-- Q6 --><question type="multichoice">
  <name><text>Rank - Effect of Elementary Row Operations</text></name>
  <questiontext format="html"><text><![CDATA[<p>Elementary row operations on a matrix \(A\):</p>]]></text></questiontext>
  <generalfeedback format="html"><text><![CDATA[<p><strong>Answer: (B) Preserve the rank of \(A\)</strong></p><p>Elementary row operations (swap rows, scale a row by nonzero scalar, add multiple of one row to another) correspond to multiplying on the left by invertible elementary matrices. Since multiplying by invertible matrices doesn't change rank, the rank is preserved. This is the basis of Gaussian elimination for computing rank.</p>]]></text></generalfeedback>
  <defaultgrade>1.0</defaultgrade><penalty>0.25</penalty><hidden>0</hidden>
  <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
