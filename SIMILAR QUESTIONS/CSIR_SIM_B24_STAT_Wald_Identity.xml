<!-- Q9 -->
<question type="multichoice">
  <name><text>Wald - General Geometric N Variance Formula</text></name>
  <questiontext format="html"><text><![CDATA[<p>Let \(N\sim\mathrm{Geometric}(p)\) with \(P(N=k)=(1-p)^{k-1}p\), \(k\ge1\), and \(X_i\) i.i.d. with mean \(\mu\) and variance \(\sigma^2\), independent of \(N\). Then \(\mathrm{Var}(S_N)\) is:</p>]]></text></questiontext>
  <generalfeedback format="html"><text><![CDATA[<p><strong>Answer: (B) \(\dfrac{\sigma^2}{p}+\dfrac{(1-p)\mu^2}{p^2}\)</strong></p><p>\(E[N]=1/p\), \(\mathrm{Var}(N)=(1-p)/p^2\). Wald: \(\mathrm{Var}(S_N)=\tfrac{1}{p}\sigma^2+\tfrac{1-p}{p^2}\mu^2\).</p>]]></text></generalfeedback>
  <defaultgrade>1.0</defaultgrade><penalty>0.25</penalty><hidden>0</hidden>
  <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
  <answer fraction="0" format="html"><text>\(\dfrac{\sigma^2+\mu^2}{p}\)</text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="100" format="html"><text>\(\dfrac{\sigma^2}{p}+\dfrac{(1-p)\mu^2}{p^2}\)</text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text>\(\dfrac{\sigma^2}{p^2}\)</text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text>\(\dfrac{\mu^2}{p}\)</text><feedback format="html"><text></text></feedback></answer>
</question>

