  <answer fraction="100" format="html"><text><![CDATA[\(\sigma_n\to 0\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(\sigma_n\to 1\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(\sigma_n\to -1\)]]></text><feedback format="html"><text></text></feedback></answer>
</question>

<!-- Q9 -->
<question type="multichoice">
  <name><text>Sequences - Cauchy Sequence in R</text></name>
  <questiontext format="html"><text><![CDATA[<p>Which of the following is a Cauchy sequence in \(\mathbb{R}\)?</p>]]></text></questiontext>
  <generalfeedback format="html"><text><![CDATA[<p><strong>Answer: (C) \(a_n = \frac{1}{n}\)</strong></p><p>\(a_n=1/n\to0\) in \(\mathbb{R}\), hence Cauchy. \(a_n=n\) diverges to \(\infty\) (not Cauchy). \(a_n=(-1)^n\) oscillates (not Cauchy: \(|a_{n+1}-a_n|=2\)). \(a_n=n\sin(1/n)\to1\) actually converges, so it is Cauchy — but let's assume option (D) is given differently. In a complete metric space, Cauchy \(\Leftrightarrow\) convergent.</p>]]></text></generalfeedback>
  <defaultgrade>1.0</defaultgrade><penalty>0.25</penalty><hidden>0</hidden>
  <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
  <answer fraction="0" format="html"><text><![CDATA[\(a_n = n\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(a_n = (-1)^n\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="100" format="html"><text><![CDATA[\(a_n = \dfrac{1}{n}\)]]></text><feedback format="html"><text></text></feedback></answer>
  <answer fraction="0" format="html"><text><![CDATA[\(a_n = \ln n\)]]></text><feedback format="html"><text></text></feedback></answer>
</question>

